{
  "host": "127.0.0.1",
  "port": 4400,
  "pollIntervalMs": 2500,
  "flowTimeoutMinutes": 120,
  "dbInspector": {
    "enabled": true,
    "cwd": ""
  },
  "repos": {
    "preprocessor": "",
    "planner": "",
    "interviewer": ""
  },
  "services": {
    "preprocessor-api": {
      "label": "Preprocessor API",
      "cwd": "",
      "url": "http://127.0.0.1:8010",
      "health": "http://127.0.0.1:8010/healthz",
      "command": "uv run uvicorn apps.api.main:app --host 127.0.0.1 --port 8010 --reload",
      "env": {
        "TASK_DISPATCH_BACKEND": "local_http",
