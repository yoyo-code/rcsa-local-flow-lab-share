        "RESUME_INCOMPLETE_TASKS": "false",
        "EVENT_DRIVEN_MODE": "true",
        "LOCAL_EVENT_SINK_URL": "http://127.0.0.1:4400/api/events",
        "SUBPROCESS_AUTO_DISPATCH_PLANNER": "false"
      }
    },
